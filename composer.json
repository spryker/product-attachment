{
    "name": "spryker/product-attachment",
    "type": "library",
    "description": "ProductAttachment module",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "spryker/data-import": "^1.3.0",
        "spryker/event-behavior": "^1.32.0",
        "spryker/kernel": "^3.76.0",
        "spryker/locale": "^4.0.0",
        "spryker/product": "^6.26.0",
        "spryker/product-extension": "^1.5.0",
        "spryker/product-management-extension": "^1.11.0",
        "spryker/propel-orm": "^1.0.0",
        "spryker/symfony": "^3.19.2",
        "spryker/transfer": "^3.27.0",
        "spryker/translator": "^1.14.3"
    },
    "require-dev": {
        "spryker/code-sniffer": "*",
        "spryker/propel": "*",
        "spryker/testify": "*"
    },
    "autoload": {
        "psr-4": {
            "Spryker\\": "src/Spryker/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SprykerTest\\": "tests/SprykerTest/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs-check": "phpcs -p -s --standard=vendor/spryker/code-sniffer/Spryker/ruleset.xml src/ tests/",
        "cs-fix": "phpcbf -p --standard=vendor/spryker/code-sniffer/Spryker/ruleset.xml src/ tests/"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
