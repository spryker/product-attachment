<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="ProductAttachment" strict="true">
        <property name="idProductAttachment" type="int"/>
        <property name="fkLocale" type="int"/>
        <property name="label" type="string"/>
        <property name="url" type="string"/>
        <property name="sortOrder" type="int"/>
    </transfer>

    <transfer name="ProductAttachmentProductAbstract" strict="true">
        <property name="idProductAttachmentProductAbstract" type="int"/>
        <property name="fkProductAttachment" type="int"/>
        <property name="fkProductAbstract" type="int"/>
        <property name="order" type="int"/>
    </transfer>

    <transfer name="ProductAttachmentCriteria" strict="true">
        <property name="idProductAttachment" type="int"/>
        <property name="productAttachmentCondition" type="ProductAttachmentCondition"/>
        <property name="withProductAbstractRelation" type="bool"/>
        <property name="filter" type="Filter"/>
        <property name="sortCollection" type="Sort[]" singular="sort"/>
    </transfer>

    <transfer name="ProductAttachmentCondition" strict="true">
        <property name="productAttachmentIds" type="int[]" singular="idProductAttachment"/>
        <property name="productAbstractIds" type="int[]" singular="idProductAbstract"/>
        <property name="localeIds" type="int[]" singular="idLocale"/>
    </transfer>

    <transfer name="ProductAttachmentCollection" strict="true">
        <property name="productAttachments" type="ProductAttachment[]" singular="productAttachment"/>
    </transfer>

    <transfer name="ProductAbstract">
        <property name="productAttachments" type="ProductAttachment[]" singular="productAttachment"/>
    </transfer>

    <transfer name="Locale">
        <property name="idLocale" type="int"/>
        <property name="localeName" type="string"/>
    </transfer>

    <transfer name="Filter">
        <property name="offset" type="int"/>
        <property name="limit" type="int"/>
    </transfer>

    <transfer name="Sort">
        <property name="field" type="string"/>
        <property name="isAscending" type="bool"/>
    </transfer>

    <transfer name="DataImporterConfiguration">
        <property name="importType" type="string"/>
        <property name="readerConfiguration" type="DataImporterReaderConfiguration"/>
    </transfer>

    <transfer name="DataImporterDataSourceConfiguration">
        <property name="importType" type="string"/>
        <property name="fileName" type="string"/>
        <property name="moduleName" type="string"/>
        <property name="directory" type="string"/>
    </transfer>

    <transfer name="DataImporterReaderConfiguration">
        <property name="fileName" type="string"/>
    </transfer>

    <transfer name="DataImporterReport">
    </transfer>

</transfers>
